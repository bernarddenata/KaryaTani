# Database
DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=karyatani_center
DB_USERNAME=karyatani
DB_PASSWORD=<ISI_DI_ENV_SERVER>
DATABASE_URL=postgresql://karyatani:<ISI_DI_ENV_SERVER>@localhost:5432/karyatani_center

# App
APP_NAME="Karya Tani Center"
APP_ENV=development
APP_URL=http://localhost:3000
APP_PORT=3000

# Auth
JWT_SECRET=change-this-jwt-secret
NEXTAUTH_SECRET=change-this-secret
NEXTAUTH_URL=http://localhost:3000

# Storage (local fallback if R2 not configured)
UPLOAD_STORAGE_PROVIDER=local
LOCAL_UPLOAD_PATH=./uploads

# Cloudflare R2 (optional — leave empty to use local storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=karyatani-bucket
R2_PUBLIC_URL=
