// ============================================================================
// FARMER APP SUPPORT (devices & dispute messages)
// ============================================================================

model FarmerDevice {
  id           String   @id @default(uuid())
  farmer_id    String
  device_token String
  platform     String   @default("android")
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  farmer Farmer @relation(fields: [farmer_id], references: [id])

  @@unique([farmer_id, device_token])
  @@index([farmer_id])
  @@map("KaryaTani_farmer_devices")
}

model DisputeMessage {
  id               String   @id @default(uuid())
  dispute_id       String
  sender_type      String // FARMER | KOPERASI
  sender_farmer_id String?
  sender_user_id   String?
  message          String
  created_at       DateTime @default(now())

  dispute       Dispute @relation(fields: [dispute_id], references: [id])
  sender_farmer Farmer? @relation("FarmerDisputeMessages", fields: [sender_farmer_id], references: [id])
  sender_user   User?   @relation("UserDisputeMessages", fields: [sender_user_id], references: [id])

  @@index([dispute_id])
  @@index([sender_farmer_id])
  @@index([sender_user_id])
  @@map("KaryaTani_dispute_messages")
}

// ============================================================================
// FILES, NOTIFICATIONS & AUDIT
// ============================================================================

model FileUpload {
  id                  String   @id @default(uuid())
  file_url            String
  file_name           String
  file_type           String
  file_size           Int
  storage_provider    String
  uploaded_by_user_id String?
  entity_type         String?
  entity_id           String?
  created_at          DateTime @default(now())

  // Relations
  uploaded_by          User?             @relation("UploadedByFiles", fields: [uploaded_by_user_id], references: [id])
  source_proof_files   FarmerSource[]    @relation("SourceProofFile")
  sale_photo_files     FarmerSalePhoto[] @relation("SalePhotoFile")
  result_item_proofs   QcResultItem[]    @relation("ResultItemProofFile")
  payout_proof_files   FarmerPayout[]    @relation("PayoutProofFile")
  adjustment_proofs    StockAdjustment[] @relation("AdjustmentProofFile")
  disposal_proofs      StockDisposal[]   @relation("DisposalProofFile")
  delivery_documents   StockDelivery[]   @relation("DeliveryDocumentFile")
  delivery_proofs      StockDelivery[]   @relation("DeliveryProofFile")

  @@index([uploaded_by_user_id])
  @@map("KaryaTani_files")
}

model Notification {
  id                  String   @id @default(uuid())
  user_id             String?
  farmer_id           String?
  title               String
  message             String
  notification_type   String
  related_entity_type String?
  related_entity_id   String?
  is_read             Boolean  @default(false)
  created_at          DateTime @default(now())

  // Relations
  user   User?   @relation("UserNotifications", fields: [user_id], references: [id])
  farmer Farmer? @relation("FarmerNotifications", fields: [farmer_id], references: [id])

  @@index([user_id])
  @@index([farmer_id])
  @@map("KaryaTani_notifications")
}

model AuditLog {
  id            String   @id @default(uuid())
  actor_user_id String?
  entity_type   String
  entity_id     String?
  action        String
  before_json   Json?
  after_json    Json?
  source_client String
  ip_address    String?
  user_agent    String?
  created_at    DateTime @default(now())

  // Relations
  actor User? @relation("ActorAuditLogs", fields: [actor_user_id], references: [id])

  @@index([actor_user_id])
  @@index([entity_type, entity_id])
  @@map("KaryaTani_audit_logs")
}
